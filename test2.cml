
namespace clib
{
    external int printf(byte* fmt, ...);
    external FILE* fopen(byte* path, byte* mode);
    external FILE* fdopen(int fd, byte* mode);
    external byte* fgets(byte* buffer, int size, FILE* stream);
    external int atoi(byte* str);
    external int strlen(byte* str);

    struct FILE
    {
        byte[216] _,
    }
}
import clib;

struct string
{
    byte* data,
    long length,

    string from_cstr(byte* str)
    {
        long len = strlen(str);
        string ret;
        ret.data = str;
        ret.length = len;
        return ret;
    }
}

void print(string str)
    printf("%.*s", str.length, str.data);

export int main()
{
    string str = string.from_cstr("Hello, world");
    print(str);
    printf("\n");

    return 0;
}
