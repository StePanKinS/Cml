
namespace clib
{
    external int printf(byte* fmt, ...);
}
import clib;

struct Point {
    int x,
    int y

    Point new(int n)
    {
        return { n, n };
    }

    void print(Point* self)
    {
        printf("Point(%d, %d)\n", (void*)(ulong)(long)self.x, (void*)(ulong)(long)self.y);
    }
}

export int main(int argc, byte** argv)
{
    Point p = { 10, 5 };
    Point pn = { x: 3, y: 9 };
    p.print();
    pn.print();
    Point pp = Point.new(7);
    pp.print();
    return 0;
}
